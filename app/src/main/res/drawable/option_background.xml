<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <solid android:color="#E0F2F1" /> <stroke android:width="2dp" android:color="#00796B" /> <corners android:radius="12dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#FFFFFF" /> <stroke android:width="1dp" android:color="#DCDCDC" /> <corners android:radius="12dp" />
        </shape>
    </item>
</selector>