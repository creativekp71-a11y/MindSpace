<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.OnlineExamApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6C5CE7</item>
        <item name="colorPrimaryVariant">#5B4BCB</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Standard Text Colors restored to pure black -->
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#757575</item>
        <item name="android:editTextColor">#000000</item>
        <item name="android:textColorHint">#888888</item>

        <!-- Secondary / Accent color -->
        <item name="colorSecondary">#6C5CE7</item>
        <item name="colorSecondaryVariant">#5B4BCB</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorAccent">#6C5CE7</item>
        <item name="android:windowBackground">#F5F6FA</item>
        <item name="android:statusBarColor">#6C5CE7</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- Circle Style for ShapeableImageView -->
    <style name="CircleImageViewShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="CircleImageView" parent="Widget.MaterialComponents.ShapeableImageView">
        <item name="shapeAppearanceOverlay">@style/CircleImageViewShape</item>
    </style>

    <style name="Theme.Cropper" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">#6C5CE7</item>
        <item name="colorPrimaryVariant">#5B4BCB</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">?android:attr/colorBackground</item>
    </style>

    <!-- Smooth Shimmer Style -->
    <style name="ShimmerStyle">
        <item name="shimmer_duration">1500</item>
        <item name="shimmer_intensity">0.1</item>
        <item name="shimmer_base_alpha">1.0</item>
        <item name="shimmer_highlight_alpha">0.6</item>
        <item name="shimmer_auto_start">true</item>
        <item name="shimmer_repeat_delay">100</item>
    </style>
</resources>