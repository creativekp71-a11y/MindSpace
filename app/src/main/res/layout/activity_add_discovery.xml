<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground">

    <!-- Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_above="@id/bottomNavBar">

        <!-- Header (Consolidated Style) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:paddingHorizontal="16dp"
            android:background="?android:attr/colorBackground"
            android:elevation="4dp">
            
            <ImageView
                android:id="@+id/ivBackAddDiscovery"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back"
                android:padding="4dp"
                app:tint="?android:attr/textColorPrimary" />
                
            <TextView
                android:id="@+id/tvAddDiscoveryHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Discovery"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"
                android:textColor="?android:attr/textColorPrimary"/>
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp">
... [Rest of the internal content remains same, I will use multi_replace for less text] ...

            <!-- Be an Author Toggle Row (Slim Version) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:id="@+id/tvBeAnAuthorLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✍️  Be an Author"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_centerVertical="true" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBecomeAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="#6C5CE7"
                    app:trackTint="#D1C4E9" />
            </RelativeLayout>

            <View
                android:id="@+id/dividerAuthor"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvSectionCover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity Cover Photo"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDiscoveryCover"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivDiscoveryCoverPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/cover_photo" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#4D000000" />

                    <LinearLayout
                        android:id="@+id/btnChangeDiscoveryCover"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:background="?android:attr/listDivider"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_camera"
                            app:tint="#6C5CE7" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Upload Cover"
                            android:textColor="#6C5CE7"
                            android:textStyle="bold" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity Title"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etDiscoveryTitle"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Enter activity title"
                android:paddingHorizontal="16dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary"
                android:background="@drawable/bg_option"
                android:layout_marginBottom="20dp" />



            <TextView
                android:id="@+id/tvSectionCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz Category"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />
                
            <EditText
                android:id="@+id/etDiscoveryCategory"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="e.g. Science, Math, GK, etc..."
                android:paddingHorizontal="16dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary"
                android:background="@drawable/bg_option"
                android:layout_marginBottom="24dp" />

            <!-- Questions Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:id="@+id/tvSectionQuestions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Questions"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    android:textSize="18sp" />
                
                <TextView
                    android:id="@+id/tvQuestionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0 added"
                    android:textColor="#6C5CE7"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAddedQuestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAddQuestionDialog"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="➕ Add New Question"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#6C5CE7"
                android:background="@drawable/bg_option"
                android:layout_marginBottom="32dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAddDiscovery"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Save Activity"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_follow"
                android:elevation="4dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Persistent Bottom Navigation Bar -->
    <include
        android:id="@+id/bottomNavBar"
        layout="@layout/layout_bottom_navigation" />

</RelativeLayout>
