<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FC"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fitsSystemWindows="false">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerBg"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@drawable/bg_admin_header_premium"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <ImageView
                android:id="@+id/ivLogout"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_trans"
                android:padding="11dp"
                android:src="@drawable/ic_logout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvWelcomeBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="50dp"
                android:text="Welcome back,"
                android:textColor="#B2BEC3"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvAdminTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="Admin Center"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvWelcomeBack" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:text="Managing MindSpace Platform"
                android:textColor="#DFE6E9"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvAdminTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingBottom="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical">

                <!-- Stats Summary -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="-60dp"
                    android:layout_marginEnd="16dp"
                    android:columnCount="2"
                    android:rowCount="1">

                    <!-- Quizzes Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTotalQuizzes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:strokeColor="#1A000000"
                        app:strokeWidth="1dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <View
                                android:id="@+id/bgIconQuizzes"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_alignParentEnd="true"
                                android:background="@drawable/bg_icon_circle_purple_soft" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignStart="@id/bgIconQuizzes"
                                android:layout_alignTop="@id/bgIconQuizzes"
                                android:layout_alignEnd="@id/bgIconQuizzes"
                                android:layout_alignBottom="@id/bgIconQuizzes"
                                android:src="@drawable/ic_nav_quiz"
                                app:tint="#6C5CE7" />

                            <TextView
                                android:id="@+id/tvTotalQuizzesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textColor="#2D3436"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_below="@id/tvTotalQuizzesCount"
                                android:text="Total Quizzes"
                                android:textColor="#636E72"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Members Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTotalMembers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:strokeColor="#1A000000"
                        app:strokeWidth="1dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <View
                                android:id="@+id/bgIconMembers"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_alignParentEnd="true"
                                android:background="@drawable/bg_icon_circle_blue_soft" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignStart="@id/bgIconMembers"
                                android:layout_alignTop="@id/bgIconMembers"
                                android:layout_alignEnd="@id/bgIconMembers"
                                android:layout_alignBottom="@id/bgIconMembers"
                                android:src="@drawable/ic_nav_profile"
                                app:tint="#0984E3" />

                            <TextView
                                android:id="@+id/tvTotalUsersCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textColor="#2D3436"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_below="@id/tvTotalUsersCount"
                                android:text="Total Members"
                                android:textColor="#636E72"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>

                <!-- Administrative Controls -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:text="Administrative Controls"
                    android:textColor="#2D3436"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Manage Users Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManageUsers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <View
                            android:id="@+id/btnIconUser"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_icon_circle_purple_soft" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="-38dp"
                            android:src="@drawable/ic_search"
                            app:tint="#6C5CE7" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="26dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Manage Platform Users"
                                android:textColor="#2D3436"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Suspend, Delete or Block members"
                                android:textColor="#636E72"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.3"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            app:tint="@color/black" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Broadcast Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBroadcast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <View
                            android:id="@+id/btnIconBroadcast"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_icon_circle_blue_soft" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="-38dp"
                            android:src="@drawable/ic_chat_plane"
                            app:tint="#0984E3" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="26dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Broadcast Notification"
                                android:textColor="#2D3436"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Announce to all platform users"
                                android:textColor="#636E72"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.3"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            app:tint="@color/black" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Author Management Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHealthReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#1A000000"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <View
                            android:id="@+id/btnIconAuthor"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_icon_circle_emerald_soft" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="-38dp"
                            android:src="@drawable/ic_nav_trophy"
                            app:tint="#00B894" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="26dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Author Oversight"
                                android:textColor="#2D3436"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verify or manage official contributors"
                                android:textColor="#636E72"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.3"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            app:tint="@color/black" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
