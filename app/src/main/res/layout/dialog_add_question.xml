<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_white"
    android:padding="20dp"
    android:layout_margin="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Question"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etQuestionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Question"
        android:minHeight="48dp"
        android:background="@drawable/bg_rounded_white"
        android:padding="12dp"
        android:elevation="1dp"
        android:layout_marginBottom="12dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:columnOrderPreserved="false"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etOptionA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:hint="Option A"
            android:background="@drawable/bg_rounded_white"
            android:padding="12dp"
            android:elevation="1dp"
            android:layout_margin="4dp" />

        <EditText
            android:id="@+id/etOptionB"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:hint="Option B"
            android:background="@drawable/bg_rounded_white"
            android:padding="12dp"
            android:elevation="1dp"
            android:layout_margin="4dp" />

        <EditText
            android:id="@+id/etOptionC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:hint="Option C"
            android:background="@drawable/bg_rounded_white"
            android:padding="12dp"
            android:elevation="1dp"
            android:layout_margin="4dp" />

        <EditText
            android:id="@+id/etOptionD"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:hint="Option D"
            android:background="@drawable/bg_rounded_white"
            android:padding="12dp"
            android:elevation="1dp"
            android:layout_margin="4dp" />

    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Correct Answer (Exact Option Text)"
        android:textStyle="bold"
        android:textColor="#2F3640"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etCorrectAnswer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. Einstein"
        android:background="@drawable/bg_rounded_white"
        android:padding="12dp"
        android:elevation="1dp"
        android:layout_marginBottom="24dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirmAddQuestion"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Add Question to List"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_btn_follow" />

</LinearLayout>
