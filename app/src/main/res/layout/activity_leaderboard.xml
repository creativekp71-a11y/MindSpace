<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA"
    android:fitsSystemWindows="true">

    <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:background="#FFFFFF"
    android:paddingHorizontal="16dp"
    android:elevation="4dp">

    <ImageView
        android:id="@+id/ivBackLeaderboard"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_centerVertical="true"
        android:padding="4dp"
        android:src="@drawable/ic_back"
        app:tint="#000000" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/ivBackLeaderboard"
        android:layout_marginStart="16dp"
        android:text="Global Rankings 🏆"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />
</RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3CD">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvRank1"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="#1"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFB142"
                        android:layout_centerVertical="true"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvPic1"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_toEndOf="@id/tvRank1"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_fd2" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/cvPic1"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sahil"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1450 Points"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥇"
                        android:textSize="32sp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E2E3E5">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvRank2"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="#2"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#8395A7"
                        android:layout_centerVertical="true"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvPic2"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_toEndOf="@id/tvRank2"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_fd7" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/cvPic2"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dhruvi"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1200 Points"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥈"
                        android:textSize="32sp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F8DED2">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvRank3"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="#3"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#D980FA"
                        android:layout_centerVertical="true"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvPic3"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_toEndOf="@id/tvRank3"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_fd" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/cvPic3"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="kp"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="950 Points"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥉"
                        android:textSize="32sp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                android:layout_marginBottom="8dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tvRank4"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="#4"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#A4B0BE"
                        android:layout_centerVertical="true"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvPic4"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_toEndOf="@id/tvRank4"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_fd3" />

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/cvPic4"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ravi"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2F3640"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="820 Points"
                            android:textSize="12sp"
                            android:textColor="#7F8FA6"/>

                    </LinearLayout>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" android:layout_marginBottom="8dp" app:cardElevation="1dp" app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp">
                    <TextView android:id="@+id/tvRank5" android:layout_width="40dp" android:layout_height="wrap_content" android:text="#5" android:textSize="20sp" android:textStyle="bold" android:textColor="#A4B0BE" android:layout_centerVertical="true"/>
                    <androidx.cardview.widget.CardView android:id="@+id/cvPic5" android:layout_width="40dp" android:layout_height="40dp" android:layout_toEndOf="@id/tvRank5" android:layout_centerVertical="true" app:cardCornerRadius="20dp" app:cardElevation="0dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/ic_fd4" /></androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/cvPic5" android:layout_centerVertical="true" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vikram" android:textSize="16sp" android:textStyle="bold" android:textColor="#2F3640"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="750 Points" android:textSize="12sp" android:textColor="#7F8FA6"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" android:layout_marginBottom="8dp" app:cardElevation="1dp" app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp">
                    <TextView android:id="@+id/tvRank6" android:layout_width="40dp" android:layout_height="wrap_content" android:text="#6" android:textSize="20sp" android:textStyle="bold" android:textColor="#A4B0BE" android:layout_centerVertical="true"/>
                    <androidx.cardview.widget.CardView android:id="@+id/cvPic6" android:layout_width="40dp" android:layout_height="40dp" android:layout_toEndOf="@id/tvRank6" android:layout_centerVertical="true" app:cardCornerRadius="20dp" app:cardElevation="0dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/ic_fd6" /></androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/cvPic6" android:layout_centerVertical="true" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dhamo" android:textSize="16sp" android:textStyle="bold" android:textColor="#2F3640"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="690 Points" android:textSize="12sp" android:textColor="#7F8FA6"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" android:layout_marginBottom="8dp" app:cardElevation="1dp" app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp">
                    <TextView android:id="@+id/tvRank7" android:layout_width="40dp" android:layout_height="wrap_content" android:text="#7" android:textSize="20sp" android:textStyle="bold" android:textColor="#A4B0BE" android:layout_centerVertical="true"/>
                    <androidx.cardview.widget.CardView android:id="@+id/cvPic7" android:layout_width="40dp" android:layout_height="40dp" android:layout_toEndOf="@id/tvRank7" android:layout_centerVertical="true" app:cardCornerRadius="20dp" app:cardElevation="0dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/ic_fd11" /></androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/cvPic7" android:layout_centerVertical="true" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Heer" android:textSize="16sp" android:textStyle="bold" android:textColor="#2F3640"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="610 Points" android:textSize="12sp" android:textColor="#7F8FA6"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" android:layout_marginBottom="8dp" app:cardElevation="1dp" app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp">
                    <TextView android:id="@+id/tvRank8" android:layout_width="40dp" android:layout_height="wrap_content" android:text="#8" android:textSize="20sp" android:textStyle="bold" android:textColor="#A4B0BE" android:layout_centerVertical="true"/>
                    <androidx.cardview.widget.CardView android:id="@+id/cvPic8" android:layout_width="40dp" android:layout_height="40dp" android:layout_toEndOf="@id/tvRank8" android:layout_centerVertical="true" app:cardCornerRadius="20dp" app:cardElevation="0dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/ic_fd8" /></androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/cvPic8" android:layout_centerVertical="true" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Billorani" android:textSize="16sp" android:textStyle="bold" android:textColor="#2F3640"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="540 Points" android:textSize="12sp" android:textColor="#7F8FA6"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" android:layout_marginBottom="8dp" app:cardElevation="1dp" app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp">
                    <TextView android:id="@+id/tvRank9" android:layout_width="40dp" android:layout_height="wrap_content" android:text="#9" android:textSize="20sp" android:textStyle="bold" android:textColor="#A4B0BE" android:layout_centerVertical="true"/>
                    <androidx.cardview.widget.CardView android:id="@+id/cvPic9" android:layout_width="40dp" android:layout_height="40dp" android:layout_toEndOf="@id/tvRank9" android:layout_centerVertical="true" app:cardCornerRadius="20dp" app:cardElevation="0dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/ic_fd13" /></androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/cvPic9" android:layout_centerVertical="true" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bhavlo" android:textSize="16sp" android:textStyle="bold" android:textColor="#2F3640"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="480 Points" android:textSize="12sp" android:textColor="#7F8FA6"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" android:layout_marginBottom="30dp" app:cardElevation="1dp" app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp">
                    <TextView android:id="@+id/tvRank10" android:layout_width="40dp" android:layout_height="wrap_content" android:text="#10" android:textSize="20sp" android:textStyle="bold" android:textColor="#A4B0BE" android:layout_centerVertical="true"/>
                    <androidx.cardview.widget.CardView android:id="@+id/cvPic10" android:layout_width="40dp" android:layout_height="40dp" android:layout_toEndOf="@id/tvRank10" android:layout_centerVertical="true" app:cardCornerRadius="20dp" app:cardElevation="0dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/ic_fd10" /></androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/cvPic10" android:layout_centerVertical="true" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Arvin" android:textSize="16sp" android:textStyle="bold" android:textColor="#2F3640"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="410 Points" android:textSize="12sp" android:textColor="#7F8FA6"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>