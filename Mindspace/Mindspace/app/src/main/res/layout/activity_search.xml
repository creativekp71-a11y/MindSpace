<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBackSearch"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="16dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <EditText
                android:id="@+id/etSearchInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Search for quizzes..."
                android:paddingStart="20dp"
                android:paddingEnd="50dp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="#2F3640"
                android:textSize="16sp"/>

            <ImageView
                android:id="@+id/btnSearchAction"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/ic_search"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="10dp"
                android:padding="5dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSearchResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type above to find new quizzes\n(e.g., Science, Math)"
            android:textAlignment="center"
            android:textColor="#757575"
            android:textSize="16sp"/>
    </LinearLayout>

</LinearLayout>