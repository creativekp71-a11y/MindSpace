<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Find Friends"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <EditText
        android:id="@+id/etSearchFriends"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#F5F5F5"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="12dp"
        android:hint="Search email, name, or phone number"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="14sp"
        android:textColorHint="#A0A0A0"
        android:layout_marginBottom="24dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout android:id="@+id/btnContactMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                <ImageView android:id="@+id/icContact" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_con" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/icContact" android:layout_marginStart="16dp" android:layout_centerVertical="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Search Contact" android:textStyle="bold" android:textColor="#000000"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find friends by phone num..." android:textSize="12sp" android:textColor="#888888"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=">" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:textColor="#888888" android:textStyle="bold"/>
            </RelativeLayout>

            <RelativeLayout android:id="@+id/btnFacebookMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                <ImageView android:id="@+id/icFb" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_fb" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/icFb" android:layout_marginStart="16dp" android:layout_centerVertical="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Connect to Facebook" android:textStyle="bold" android:textColor="#000000"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find contacts via Facebook" android:textSize="12sp" android:textColor="#888888"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=">" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:textColor="#888888" android:textStyle="bold"/>
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btnInviteMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/icInvite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_in_fd" />

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toEndOf="@id/icInvite" android:layout_marginStart="16dp" android:layout_centerVertical="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Invite Friends" android:textStyle="bold" android:textColor="#000000"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Invite friends to play toge..." android:textSize="12sp" android:textColor="#888888"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=">" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:textColor="#888888" android:textStyle="bold"/>
            </RelativeLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="People you may know"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />
    </RelativeLayout>

